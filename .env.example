# Copy to .env and adjust as needed: cp .env.example .env

# URL subpath if served behind a reverse proxy at a path (e.g. /crl).
# Leave empty when the app has its own (sub)domain or is served at root.
URL_PREFIX=

# How often (seconds) the scheduler looks for monitors due to be checked.
SCHEDULER_INTERVAL=30

# Per-request CRL HTTP timeout (seconds).
CRL_TIMEOUT=30

# Maximum CRL download size (bytes). Larger CRLs are rejected (16 MiB default).
MAX_CRL_BYTES=16777216

# Number of status-history rows retained per monitor.
HISTORY_LIMIT=200

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
